# Supabase project URL, for example https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon public key from Project Settings > API
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service_role secret key. Keep this private and never expose it publicly.
SUPABASE_SERVICE_ROLE_KEY=

# Local app URL used for auth redirects and password reset links
NEXT_PUBLIC_APP_URL=http://localhost:3000
